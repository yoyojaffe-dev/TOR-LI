# Tor-li environment variables (copy to repo-root .env and fill in).
# Real secrets live in the gitignored root .env — never commit them.

# --- Supabase ---
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_KEY="<anon-or-service-role-key>"

# --- Google Maps (Discovery Agent + frontend map) ---
GOOGLE_MAPS_API_KEY="<google-maps-api-key>"

# --- Payments (mock until a real merchant account exists) ---
PAYMENT_API_KEY="mock_key_for_now"

# --- OpenAI (Scraping/Booking agent parsing) ---
OPENAI_API_KEY="<openai-api-key>"

# --- Twilio (notification SMS) ---
TWILIO_ACCOUNT_SID="<twilio-account-sid>"
TWILIO_AUTH_TOKEN="<twilio-auth-token>"
TWILIO_PHONE_NUMBER="+10000000000"

# --- Server ---
ENVIRONMENT="development"
PORT=8000
